{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/lightman/Documents/sites/jr-academy-ai/curriculum && result=$(git pull --rebase 2>&1) && if echo \"$result\" | grep -qv 'Already up to date'; then echo \"[auto-sync] 已拉取最新代码: $result\"; fi",
            "timeout": 15000
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Write(**/*.html)",
      "Write(**/*.css)",
      "Write(**/*.md)",
      "Write(.claude/**)",
      "Glob(**)",
      "Grep(**)",
      "Bash(bun install:*)",
      "Bash(bun run dev:*)",
      "Bash(bun run build:*)",
      "Bash(bun run preview:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(wc:*)",
      "Bash(open:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(pwd:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "WebSearch(*)",
      "WebFetch(*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push --force:*)",
      "Bash(git clean:*)"
    ]
  }
}
